# Optional overrides — the app ships with testnet defaults in src/lib/config.ts.
# Copy to .env only when pointing at a different Predict instance.
#
# VITE_USE_PREDICT_SERVER=true
# VITE_PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com
# VITE_PREDICT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
# VITE_PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
# VITE_PREDICT_REGISTRY_ID=0x43af14fed5480c20ff77e2263d5f794c35b9fab7e2212903127062f4fe2a6e64
# VITE_QUOTE_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC

# LeverX package + shared objects (after deploy_and_share).
# VITE_LEVERX_PACKAGE_ID=0xfe042fb234a20c8599227bec8cf17ace8bf21276c0f499d23f075425cd7973f2
# VITE_FEE_COLLECTOR_ID=0x…
# VITE_PYTH_QUOTE_ORACLE_ID=0x…
# VITE_LEVERX_INDEXER_URL=http://localhost:3100

# Optional LeverX collateral catalog (JSON). On-chain registry LTV is authoritative.
# Each entry needs pythOracleId for on-chain trades.
# Launch targets: BTC 80%, SUI 70%, dUSDC 100%, DEEP 60% max LTV.
# VITE_SUPPORTED_COLLATERALS=[{"symbol":"BTC","coinType":"0x…","maxLtvBps":8000},{"symbol":"SUI","coinType":"0x2::sui::SUI","maxLtvBps":7000},{"symbol":"DUSDC","coinType":"0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC","maxLtvBps":10000},{"symbol":"DEEP","coinType":"0x…","maxLtvBps":6000}]

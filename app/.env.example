# LeverX app — copy to app/.env
# Deploy IDs mirror contracts/deploy-testnet.env (override after republish).

# ── LeverX package & shared objects ───────────────────────────────────────────
VITE_LEVERX_PACKAGE_ID=0x97b41ca2ed4948d2b448ca4031d1727ee2dfd2c1e9c086748c758e069a366825
VITE_LEVERX_REGISTRY_ID=0xc165f33bffbdaf02209690f4ad7aa5090aa214bcba80e23d9be6e52db676de93
VITE_LEVERX_VAULT_ID=0x249afdb0a91126b12c262dc57ee871582376874b65ad857df54887a2145c96f3
VITE_LEVERX_FEE_COLLECTOR_ID=0xcdcee4fd12114732e8933039a3bbb3954b7db70444f351eee8cf71a62d0452fa

# ── DeepBook Predict ──────────────────────────────────────────────────────────
VITE_PREDICT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
VITE_PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138

# ── API endpoints ─────────────────────────────────────────────────────────────
# REST via keeper (proxies /v1/*). WebSocket must hit leverx-server directly.
VITE_LEVERX_KEEPER_URL=https://keeper.suileverx.xyz
VITE_LEVERX_INDEXER_URL=https://indexer.suileverx.xyz
VITE_LEVERX_INDEXER_WS_URL=wss://indexer.suileverx.xyz/v1/ws

# Local docker stack:
# VITE_LEVERX_KEEPER_URL=http://localhost:3001
# VITE_LEVERX_INDEXER_URL=http://localhost:3100
# VITE_LEVERX_INDEXER_WS_URL=ws://localhost:3100/v1/ws

# ── Keeper integration (optional) ─────────────────────────────────────────────
# Shared ops API key (not required for user-signed trade relay).
# VITE_KEEPER_API_KEY=
# Fallback when indexer has not synced registry.keeper_address yet.
# VITE_KEEPER_ADDRESS=0x...

# ── Telegram alerts (optional — portfolio Connect Telegram button) ────────────
# Must match keeper TELEGRAM_BOT_USERNAME (without @).
# VITE_TELEGRAM_BOT_USERNAME=YourLeverXBot

# ── Enoki zkLogin (required for Google sign-in) ───────────────────────────────
# VITE_ENOKI_API_KEY=
# VITE_ENOKI_GOOGLE_CLIENT_ID=

# ── Charts (optional) ─────────────────────────────────────────────────────────
# VITE_DEEPBOOK_INDEXER_URL=https://deepbook-indexer.mainnet.mystenlabs.com

# ── Market comments (Firestore) ───────────────────────────────────────────────
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=

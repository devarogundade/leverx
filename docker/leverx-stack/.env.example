# Full leverx docker stack (root docker-compose.yml)
# Copy to repo root as .env OR merge into keeper/.env (compose loads keeper/.env).

# ── Keeper signer (required) ──────────────────────────────────────────────────
KEEPER_PRIVATE_KEY=

# ── Keeper ops / Enoki (optional) ─────────────────────────────────────────────
# KEEPER_API_KEY=
# ENOKI_SECRET_KEY=enoki_private_...
# ENOKI_NETWORK=testnet

# ── Telegram alerts (optional) ────────────────────────────────────────────────
TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=YourLeverXBot
# TELEGRAM_POLLING=true
# TELEGRAM_POLL_INTERVAL_SEC=10
# Webhook: https://keeper.suileverx.xyz/telegram/webhook

# ── Postgres ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://leverx:leverx@postgres:5432/leverx_indexer
INDEXER_DATABASE_URL=postgres://leverx:leverx@postgres:5432/leverx_indexer
DATABASE_SYNCHRONIZE=true
DATABASE_LOGGING=false
PGHOST=postgres
PGPORT=5432
PGUSER=leverx

# ── Redis (BullMQ) ────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_URL=redis://redis:6379

# ── Indexer ingestion ─────────────────────────────────────────────────────────
REMOTE_STORE_URL=https://checkpoints.testnet.sui.io
STREAMING_URL=https://fullnode.testnet.sui.io:443
FIRST_CHECKPOINT=349557275

# ── Deploy IDs (from contracts/deploy-testnet.env) ────────────────────────────
LEVERX_PACKAGE_ID=0x97b41ca2ed4948d2b448ca4031d1727ee2dfd2c1e9c086748c758e069a366825
LEVERX_REGISTRY_ID=0xc165f33bffbdaf02209690f4ad7aa5090aa214bcba80e23d9be6e52db676de93
LEVERX_VAULT_ID=0x249afdb0a91126b12c262dc57ee871582376874b65ad857df54887a2145c96f3
LEVERX_FEE_COLLECTOR_ID=0xcdcee4fd12114732e8933039a3bbb3954b7db70444f351eee8cf71a62d0452fa
PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
PREDICT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com
QUOTE_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC

# ── Internal service URLs (docker network) ────────────────────────────────────
INDEXER_URL=http://127.0.0.1:3100
LEVERX_API_PORT=3100
PORT=3001
METRICS_PORT=9186
CORS_ORIGIN=https://*.suileverx.xyz,http://localhost:8080

# ── App (set in app/.env for local dev) ───────────────────────────────────────
# VITE_LEVERX_KEEPER_URL=http://localhost:3001
# VITE_LEVERX_INDEXER_WS_URL=ws://localhost:3100/v1/ws
# VITE_TELEGRAM_BOT_USERNAME=YourLeverXBot

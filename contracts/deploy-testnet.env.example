# LeverX testnet deployment IDs (fill after publish + deploy_and_share)
# Copy to deploy-testnet.env — single source of truth for docker-compose / indexer / keeper / app.
#
# Publish:
#   cd contracts && sui client publish --gas-budget 500000000
#
# Deploy shared objects (same PTB or follow-up):
#   sui client call --package $LEVERX_PACKAGE_ID --module deploy \
#     --function deploy_and_share --type-args $QUOTE_TYPE \
#     --args $ADMIN_CAP $TREASURY_CAP $PREDICT_ID --gas-budget 200000000
#
# Extract IDs from a tx digest:
#   python3 contracts/scripts/extract-deploy-ids.py <TX_DIGEST>

PUBLISH_TX_DIGEST=866WrEoHQrxvTSqK38oXXKqNigoFDUhgFYAy7HDuVbXi
FIRST_CHECKPOINT=346747492

LEVERX_PACKAGE_ID=0x81e913fc694919d1fca5ebc78c05d996a77d050a9568e6d055825acd339baae1
# Set after deploy_and_share:
# LEVERX_REGISTRY_ID=
# LEVERX_VAULT_ID=
# LEVERX_FEE_COLLECTOR_ID=
LEVERX_ADMIN_CAP_ID=0x7503282509c9f9a95888fcc50dc4d66b8addbf4664cf53ddfeedfeebc65f9fcb
LEVERX_TREASURY_CAP_ID=0x881311bae268e755931a6a5f6c08a80aee70344075e23826233deaa6d13f3ad6
LEVERX_UPGRADE_CAP_ID=0xf6e4d86af310e3c0401bd6e3555c5778e7f20d6cff62c598e43178c40f9c1f1c
LEVERX_METADATA_CAP_ID=0xe8038406f7b5b5f0475eaa237f3a6762e91168dfcc6202ec9ad724a095fd0f9e

# DeepBook Predict testnet (predict-testnet-4-16)
PREDICT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
PREDICT_REGISTRY_ID=0x43af14fed5480c20ff77e2263d5f794c35b9fab7e2212903127062f4fe2a6e64

# Quote coin type (dUSDC on testnet)
QUOTE_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC

# LP share coin type (after deploy)
LXPLP_TYPE=${LEVERX_PACKAGE_ID}::lxplp::LXPLP

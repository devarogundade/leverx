# LeverX testnet deployment IDs (fill after publish + deploy_and_share)
# Copy to deploy-testnet.env — single source of truth for docker-compose / indexer / keeper / app.
#
# Publish:
#   cd contracts && sui client publish --gas-budget 500000000
#
# Deploy shared objects (same PTB or follow-up):
#   sui client call --package $LEVERX_PACKAGE_ID --module deploy \
#     --function deploy_and_share --type-args $QUOTE_TYPE \
#     --args $ADMIN_CAP $TREASURY_CAP $PREDICT_ID --gas-budget 200000000
#
# Extract IDs from a tx digest:
#   python3 contracts/scripts/extract-deploy-ids.py <TX_DIGEST>

PUBLISH_TX_DIGEST=DKKJT6v1e5Soq1rfFytZXaGRyjQrxjEPtGQrhb7y2bD1

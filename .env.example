# LeverX monorepo — environment reference
#
# This repo uses per-service .env files. Copy the relevant example:
#   cp keeper/.env.example keeper/.env
#   cp app/.env.example app/.env
#   cp indexer/.env.example indexer/.env
#
# Docker full stack: cp docker/leverx-stack/.env.example keeper/.env
#   docker compose up --build
#
# Contract deploy IDs (single source after publish):
#   contracts/deploy-testnet.env

# See keeper/.env.example      — keeper, Redis, Postgres, Telegram, Enoki
# See app/.env.example         — VITE_* frontend
# See indexer/.env.example     — indexer + leverx-server
# See docker/leverx-stack/.env.example — combined stack defaults

# LeverX keeper — copy to keeper/.env
# Defaults for deploy IDs mirror contracts/deploy-testnet.env (override after republish).

# ── Required ──────────────────────────────────────────────────────────────────
# Ed25519 secret key (hex) for on-chain keeper tasks and trade relay.
KEEPER_PRIVATE_KEY=

# ── HTTP / ops ────────────────────────────────────────────────────────────────
# Optional shared secret for POST /keeper/run and other admin routes (header: x-keeper-api-key).
KEEPER_API_KEY=

# ── Enoki gas sponsorship (optional) ──────────────────────────────────────────
# Private Enoki API key — keeper signs txs; Enoki pays gas. NEVER expose to the frontend.
ENOKI_SECRET_KEY=enoki_private_...
ENOKI_NETWORK=testnet

# ── Redis (required — BullMQ keeper tasks + telegram notification worker) ─────
# Prefer REDIS_URL in Docker; use HOST/PORT for local dev without URL parsing.
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── PostgreSQL (required — TypeORM: telegram subscriptions, user managers) ──────
DATABASE_URL=postgres://leverx:leverx@localhost:5433/leverx_indexer
# KEEPER_DATABASE_URL=   # alias for DATABASE_URL
DATABASE_SYNCHRONIZE=true
DATABASE_LOGGING=false

# ── Indexer / RPC ─────────────────────────────────────────────────────────────
# leverx-server REST base (keeper proxies /v1/* to this URL in production).
INDEXER_URL=http://127.0.0.1:3100
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# ── Deploy IDs (optional — defaults in src/config/constants.ts) ───────────────
LEVERX_PACKAGE_ID=0x972b59d3ee7c74a01d88d0b2d895d0f6ce58fc68fdead02c974ad824bfd6b790
LEVERX_REGISTRY_ID=0xe7a1cc48e4073557ed6819a313ff1bbee4cafe50929712500782b1046660bbc0
LEVERX_VAULT_ID=0xed3e5aa7b6a148720ad4b9813eb621c6d2c14c45616b1fe11b88ee1cb057f907
LEVERX_FEE_COLLECTOR_ID=0x91fccb2929c76addfb958930901a81e59f6eff8309d6afe6c507261bbbd49468
PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
PREDICT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com
QUOTE_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC

# ── Telegram trading alerts (optional) ────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_BOT_USERNAME=YourLeverXBot
TELEGRAM_POLLING=true
TELEGRAM_POLL_INTERVAL_SEC=10
# Minimum gap between liquidation-risk alerts for the same position (ms). Default 5 minutes.
TELEGRAM_ALERT_COOLDOWN_MS=300000
# Trading auth: OTP validity (ms) and session lifetime after /auth (default 7 days).
TELEGRAM_OTP_TTL_MS=600000
TELEGRAM_SESSION_TTL_MS=604800000
TELEGRAM_MARKETS_LIMIT=10
TELEGRAM_MARKET_SLIPPAGE_BPS=100
# Webhook (only when TELEGRAM_POLLING=false): https://keeper.suileverx.xyz/telegram/webhook

# ── Jarvis autonomous AI agent (optional) ─────────────────────────────────────
JARVIS_ENABLED=true
# Required for Jarvis — LangChain agent derives all trading decisions (no heuristic fallback).
ANTHROPIC_API_KEY=
JARVIS_ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Repeatable BullMQ interval per enabled account (ms). Default 5 minutes.
JARVIS_INTERVAL_MS=300000
JARVIS_MARKETS_LIMIT=10
JARVIS_MARKET_SLIPPAGE_BPS=100
DEEPBOOK_INDEXER_URL=https://deepbook-indexer.mainnet.mystenlabs.com

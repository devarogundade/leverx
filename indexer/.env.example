# LeverX indexer + leverx-server — copy to indexer/.env
# Package IDs: keep in sync with contracts/deploy-testnet.env

# ── Postgres (required) ───────────────────────────────────────────────────────
DATABASE_URL=postgres://leverx:leverx@localhost:5432/leverx_indexer
# INDEXER_DATABASE_URL=   # alias used by docker stack entry.sh

# ── Sui checkpoint ingestion (leverx-indexer) ─────────────────────────────────
REMOTE_STORE_URL=https://checkpoints.testnet.sui.io
STREAMING_URL=https://fullnode.testnet.sui.io:443
# Resync from publish checkpoint (contracts/deploy-testnet.env FIRST_CHECKPOINT)
FIRST_CHECKPOINT=349557275

# ── Deploy filter IDs (required for event ingestion) ──────────────────────────
LEVERX_PACKAGE_ID=0x97b41ca2ed4948d2b448ca4031d1727ee2dfd2c1e9c086748c758e069a366825
PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
PREDICT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
QUOTE_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC

# ── leverx-server HTTP API ────────────────────────────────────────────────────
PORT=3100
CORS_ORIGIN=https://*.suileverx.xyz,http://localhost:8080

# ── Docker stack internals (optional locally) ─────────────────────────────────
# LEVERX_API_PORT=3100
# METRICS_PORT=9186
# PGHOST=localhost
# PGPORT=5432
# PGUSER=leverx
# RUST_LOG=info
# RUST_BACKTRACE=1

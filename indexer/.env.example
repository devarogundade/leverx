# Postgres (required)
DATABASE_URL=postgres://leverx:leverx@localhost:5432/leverx_indexer

# Deployed leverx package ID (required for filtering events)
# Package IDs: copy from contracts/deploy-testnet.env (single source of truth)
LEVERX_PACKAGE_ID=0x3a82d6ea5a802da8d552864cb64ed86aa02496f20e53acb825e9607e8c4f58c7
PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
FIRST_CHECKPOINT=347610477

REMOTE_STORE_URL=https://checkpoints.testnet.sui.io
STREAMING_URL=https://fullnode.testnet.sui.io:443

# HTTP API (leverx-server)
PORT=3100
CORS_ORIGIN=https://*.suileverx.xyz

# Indexer checkpoint source — see https://docs.sui.io/develop/accessing-data/custom-indexer/build
# Recent testnet checkpoints (last ~30 days):
# cargo run -p leverx-indexer -- --remote-store-url https://checkpoints.testnet.sui.io --first-checkpoint RECENT_SEQ
#
# Production: gRPC + GCS backfill
# cargo run -p leverx-indexer -- \
#   --remote-store-gcs mysten-testnet-checkpoints-use4 \
#   --remote-store-header x-goog-user-project:YOUR_GCP_PROJECT \
#   --streaming-url https://fullnode.testnet.sui.io:443
